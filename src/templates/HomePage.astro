---
import ArticleCard from "../components/ArticleCard.astro";
import CountdownCard from "../components/CountdownCard.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HistoryHeroTrack from "../components/HistoryHeroTrack.astro";
import Timeline from "../components/Timeline.astro";
import { getArticle } from "../data/content";
import { getHomeContent } from "../data/home";
import { getShutdownHistory } from "../data/shutdown-history";
import { getUiCopy, localizePath, otherLocale, type Locale } from "../data/locales";
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const home = getHomeContent(locale);
const history = getShutdownHistory(locale);
const ui = getUiCopy(locale);
const featuredArticles = home.featuredSlugs.map((slug) => getArticle(locale, slug)).filter(Boolean);
const switchHref = localizePath(otherLocale(locale));
---

<BaseLayout
  title={ui.home.pageTitle}
  description={home.description}
  locale={locale}
  canonicalPath={localizePath(locale)}
  alternates={{ en: localizePath("en"), zh: localizePath("zh") }}
>
  <Header locale={locale} switchHref={switchHref} />
  <main>
    <section class="page-hero">
      <div class="shell page-hero-grid">
        <article class="card hero-panel animate-rise">
          <span class="eyebrow">{home.statusEyebrow}</span>
          <h1>{home.statusTitle}</h1>
          <p class="lede">{home.statusSummary}</p>
          <div class="hero-actions">
            <a class="cta-link" href={localizePath(locale, "government-shutdown-2026")}>{ui.home.heroCta}</a>
            <span class="chip">{ui.home.heroUpdated}</span>
          </div>
        </article>

        <div class="hero-side animate-rise animate-delay-1">
          <CountdownCard
            label={home.deadlineLabel}
            deadlineIso={home.deadlineIso}
            note={home.deadlineNote}
            eyebrow={home.statusEyebrow}
            units={locale === "zh" ? ["天", "小时", "分钟", "秒"] : ["days", "hours", "minutes", "seconds"]}
          />
          <article class="card signal-panel">
            <span class="surface-label">{ui.home.signalLabel}</span>
            <h2>{home.signalTitle}</h2>
            <p>{home.signalText}</p>
          </article>
        </div>
      </div>
      <div class="shell hero-history-shell">
        <HistoryHeroTrack content={history} ctaHref={localizePath(locale, "shutdown-history")} />
      </div>
    </section>

    <section class="shell section-block">
      <div class="section-heading">
        <span class="eyebrow">{ui.home.architectureEyebrow}</span>
        <h2>{home.architectureTitle}</h2>
        <p>{home.architectureDescription}</p>
      </div>
      <div class="pillars">
        {home.pillars.map((pillar, index) => (
          <article class={`card stack-card animate-rise animate-delay-${Math.min(index + 1, 4)}`}>
            <span class="surface-label">{ui.home.lanePrefix} {index + 1}</span>
            <h3>{pillar.title}</h3>
            <p>{pillar.copy}</p>
            <a class="cta-link" href={pillar.href}>{ui.home.openPage}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="shell section-block">
      <div class="section-heading">
        <span class="eyebrow">{ui.home.fastAnswersEyebrow}</span>
        <h2>{home.fastAnswersTitle}</h2>
      </div>
      <div class="grid-two">
        {home.quickAnswers.map((item) => (
          <article class="card quick-answer">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="shell section-block">
      <div class="section-heading">
        <span class="eyebrow">{ui.home.timelineEyebrow}</span>
        <h2>{home.timelineTitle}</h2>
        <p>{home.timelineDescription}</p>
      </div>
      <Timeline events={home.timelineEvents} />
    </section>

    <section class="shell section-block">
      <div class="section-heading">
        <span class="eyebrow">{ui.home.featuredEyebrow}</span>
        <h2>{home.featuredTitle}</h2>
      </div>
      <div class="grid-three">
        {featuredArticles.map((article) => (
          <ArticleCard
            href={localizePath(locale, article!.slug)}
            category={article!.category}
            title={article!.title}
            description={article!.description}
            updated={article!.updated}
            ctaLabel={ui.article.readGuide}
          />
        ))}
      </div>
    </section>
  </main>
  <Footer locale={locale} />
</BaseLayout>

<style>
  .section-block {
    padding: 0 0 3.2rem;
  }

  .hero-panel,
  .signal-panel,
  .quick-answer,
  .stack-card {
    padding: 1.35rem;
  }

  .hero-panel {
    min-height: 100%;
    position: relative;
    overflow: hidden;
  }

  .hero-panel::after {
    content: "";
    position: absolute;
    inset: auto -12% -18% auto;
    width: 260px;
    aspect-ratio: 1;
    border-radius: 50%;
    border: 1px dashed rgba(180, 59, 36, 0.32);
    transform: rotate(18deg);
  }

  .hero-panel h1 {
    margin: 0.6rem 0 1rem;
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.9;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    max-width: 12ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin-top: 1.2rem;
  }

  .hero-side {
    display: grid;
    gap: 1rem;
  }

  .hero-history-shell {
    margin-top: 1rem;
  }

  .signal-panel h2,
  .stack-card h3,
  .quick-answer h3 {
    margin: 0.55rem 0 0.7rem;
    font-family: "Barlow Condensed", Impact, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 0.95;
  }

  .signal-panel h2 {
    font-size: clamp(1.9rem, 3vw, 2.8rem);
  }

  .stack-card h3,
  .quick-answer h3 {
    font-size: 1.7rem;
  }

  .signal-panel p,
  .stack-card p,
  .quick-answer p {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.8;
  }

  @media (max-width: 980px) {
    .hero-panel h1 {
      max-width: none;
    }
  }
</style>
