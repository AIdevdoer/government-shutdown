---
import { getUiCopy, type Locale } from "../data/locales";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = getUiCopy(locale);
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <section class="card footer-panel">
      <span class="surface-label">{ui.footer.eyebrow}</span>
      <h2>{ui.footer.title}</h2>
      <p>{ui.footer.body}</p>
    </section>
    <section class="card footer-panel">
      <span class="surface-label">{ui.footer.linksEyebrow}</span>
      <div class="footer-links">
        {ui.footer.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
      <p class="notice">{ui.footer.contact}</p>
    </section>
  </div>
</footer>

<style>
  .site-footer {
    padding: 0 0 2rem;
  }

  .footer-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1.2fr 0.9fr;
  }

  .footer-panel {
    padding: 1.35rem;
  }

  .footer-panel h2 {
    margin: 0.5rem 0 0.8rem;
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .footer-panel p {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.8;
  }

  .footer-links {
    display: grid;
    gap: 0.65rem;
    margin-top: 0.75rem;
  }

  .footer-links a {
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (max-width: 820px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
