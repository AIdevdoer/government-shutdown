---
import type { ShutdownHistoryEvent } from "../data/shutdown-history";

interface Props {
  events: ShutdownHistoryEvent[];
}

const { events } = Astro.props;
---

<section class="history-list">
  {events.map((event, index) => (
    <article class={`history-row ${index % 2 === 0 ? "is-left" : "is-right"}`}>
      <div class="card history-copy">
        <div class="history-copy-head">
          <span class="surface-label">{event.fiscalYear}</span>
          <span class="chip">{event.duration}</span>
        </div>
        <p class="history-meta">{event.span}</p>
        <h3>{event.title}</h3>
        <p>{event.summary}</p>
      </div>

      <div class="history-pin" aria-hidden="true">
        <span class="history-pin-dot"></span>
        <span class="history-pin-year">{event.year}</span>
      </div>

      <div class="history-spacer" aria-hidden="true"></div>
    </article>
  ))}
</section>

<style>
  .history-list {
    display: grid;
    gap: 0.2rem;
    position: relative;
    padding: 0.5rem 0;
  }

  .history-list::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 2px;
    background:
      linear-gradient(180deg, rgba(180, 59, 36, 0), rgba(180, 59, 36, 0.4) 12%, rgba(144, 113, 69, 0.42) 50%, rgba(180, 59, 36, 0.4) 88%, rgba(180, 59, 36, 0));
    transform: translateX(-50%);
  }

  .history-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 7.5rem minmax(0, 1fr);
    gap: 1.4rem;
    align-items: center;
    min-height: 15rem;
    position: relative;
  }

  .history-copy {
    padding: 1.2rem 1.2rem 1.25rem;
    display: grid;
    gap: 0.8rem;
    position: relative;
    overflow: hidden;
  }

  .history-copy::after {
    content: "";
    position: absolute;
    inset: auto -14% -50% auto;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(180, 59, 36, 0.1), transparent 72%);
    pointer-events: none;
  }

  .history-copy-head {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
  }

  .history-meta,
  .history-copy p {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.8;
  }

  .history-meta {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .history-copy h3 {
    margin: 0;
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .history-pin {
    display: grid;
    justify-items: center;
    gap: 0.75rem;
    position: relative;
    z-index: 1;
  }

  .history-pin::before {
    content: "";
    width: 2px;
    height: 4.5rem;
    background: linear-gradient(180deg, rgba(144, 113, 69, 0.08), rgba(180, 59, 36, 0.38));
  }

  .history-pin::after {
    content: "";
    width: 2px;
    height: 4.5rem;
    background: linear-gradient(180deg, rgba(180, 59, 36, 0.38), rgba(144, 113, 69, 0.08));
  }

  .history-pin-dot {
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    background: linear-gradient(180deg, #cf6546, #8f2b19);
    box-shadow:
      0 0 0 6px rgba(180, 59, 36, 0.14),
      0 0 0 12px rgba(144, 113, 69, 0.08);
  }

  .history-pin-year {
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: clamp(1.6rem, 2.4vw, 2.2rem);
    line-height: 0.9;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--navy);
    text-align: center;
  }

  .history-spacer {
    min-height: 1px;
  }

  .history-row.is-right .history-copy {
    grid-column: 3;
  }

  .history-row.is-right .history-spacer {
    grid-column: 1;
  }

  .history-row.is-left .history-copy {
    grid-column: 1;
  }

  .history-row.is-left .history-spacer {
    grid-column: 3;
  }

  .history-row.is-left .history-copy::before,
  .history-row.is-right .history-copy::before {
    content: "";
    position: absolute;
    top: 50%;
    width: 2.4rem;
    height: 1px;
    background: rgba(144, 113, 69, 0.34);
  }

  .history-row.is-left .history-copy::before {
    right: -2.4rem;
  }

  .history-row.is-right .history-copy::before {
    left: -2.4rem;
  }

  :global(html[lang="zh-CN"]) .history-copy h3,
  :global(html[lang="zh-CN"]) .history-pin-year {
    font-family: "Noto Sans SC", "PingFang SC", sans-serif;
    text-transform: none;
    letter-spacing: 0.01em;
  }

  :global(html[lang="zh-CN"]) .history-meta {
    font-family: "Noto Sans SC", "PingFang SC", sans-serif;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  @media (max-width: 820px) {
    .history-list::before {
      left: 1rem;
      transform: none;
    }

    .history-row {
      grid-template-columns: 2.5rem minmax(0, 1fr);
      gap: 0.95rem;
      min-height: auto;
      padding-left: 0;
    }

    .history-copy,
    .history-row.is-left .history-copy,
    .history-row.is-right .history-copy {
      grid-column: 2;
    }

    .history-copy::before,
    .history-row.is-left .history-copy::before,
    .history-row.is-right .history-copy::before {
      display: none;
    }

    .history-pin {
      grid-column: 1;
      gap: 0.55rem;
      align-self: stretch;
    }

    .history-pin::before,
    .history-pin::after {
      height: 100%;
      min-height: 1.6rem;
    }

    .history-pin-year {
      font-size: 1.2rem;
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      letter-spacing: 0.12em;
    }

    .history-spacer {
      display: none;
    }
  }
</style>
