---
import type { ShutdownHistoryContent } from "../data/shutdown-history";

interface Props {
  content: ShutdownHistoryContent;
  ctaHref: string;
}

const { content, ctaHref } = Astro.props;
const componentId = `history-rail-${Math.random().toString(36).slice(2, 8)}`;
---

<section class="card history-hero" data-history-rail={componentId}>
  <div class="history-hero-header">
    <div class="section-heading">
      <span class="eyebrow">{content.eyebrow}</span>
      <h2>{content.highlightTitle}</h2>
      <p>{content.highlightText}</p>
    </div>
    <div class="history-stats">
      {content.stats.map((stat) => (
        <article class="history-stat">
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
          {stat.note && <small>{stat.note}</small>}
        </article>
      ))}
    </div>
  </div>

  <div class="history-track-shell">
    <div class="history-track-copy">
      <span class="surface-label">{content.railLabel}</span>
      <p>{content.railInstruction}</p>
    </div>

    <div class="history-track-frame">
      <div class="history-track-scroll" data-history-scroll>
        <div class="history-track" role="tablist" aria-label={content.highlightTitle}>
          {content.highlights.map((event, index) => {
            const panelId = `${componentId}-panel-${index}`;
            const tabId = `${componentId}-tab-${index}`;
            const isActive = index === 0;

            return (
              <button
                class={`history-stop ${index % 2 === 0 ? "is-top" : "is-bottom"}`}
                type="button"
                id={tabId}
                role="tab"
                aria-controls={panelId}
                aria-selected={isActive ? "true" : "false"}
                tabindex={isActive ? "0" : "-1"}
                data-history-tab
                data-index={index}
              >
                <span class="history-stop-card">
                  <span class="history-stop-duration">{event.duration}</span>
                  <strong>{event.title}</strong>
                </span>
                <span class="history-stop-marker">
                  <span class="history-stop-dot" aria-hidden="true"></span>
                  <span class="history-stop-year">{event.year}</span>
                </span>
              </button>
            );
          })}
        </div>
      </div>
    </div>
  </div>

  <div class="history-detail-stage">
    {content.highlights.map((event, index) => {
      const panelId = `${componentId}-panel-${index}`;
      const tabId = `${componentId}-tab-${index}`;

      return (
        <article
          class="history-detail"
          id={panelId}
          role="tabpanel"
          aria-labelledby={tabId}
          data-history-panel
          data-index={index}
          hidden={index !== 0}
        >
          <div class="history-detail-head">
            <span class="chip">{event.fiscalYear}</span>
            <span class="chip">{event.duration}</span>
          </div>
          <p class="history-hit-meta">{event.span}</p>
          <h3>{event.title}</h3>
          <p>{event.summary}</p>
        </article>
      );
    })}
  </div>

  <div class="history-hero-footer">
    <p>{content.disclaimerText}</p>
    <a class="cta-link" href={ctaHref}>{content.highlightCtaLabel}</a>
  </div>
</section>

<script>
  (() => {
    const rails = document.querySelectorAll("[data-history-rail]");

    rails.forEach((rail) => {
      if (!(rail instanceof HTMLElement)) return;

      const scroll = rail.querySelector("[data-history-scroll]");
      const tabs = Array.from(rail.querySelectorAll("[data-history-tab]"));
      const panels = Array.from(rail.querySelectorAll("[data-history-panel]"));

      if (!(scroll instanceof HTMLElement) || tabs.length === 0 || panels.length === 0) return;

      let pointerActive = false;
      let dragMoved = false;
      let suppressClick = false;
      let startX = 0;
      let startScrollLeft = 0;

      const activate = (nextIndex, shouldCenter = true) => {
        tabs.forEach((tab, index) => {
          if (!(tab instanceof HTMLElement)) return;

          const active = index === nextIndex;
          tab.setAttribute("aria-selected", active ? "true" : "false");
          tab.setAttribute("tabindex", active ? "0" : "-1");
          tab.classList.toggle("is-active", active);

          if (active && shouldCenter) {
            tab.scrollIntoView({
              behavior: "smooth",
              block: "nearest",
              inline: "center"
            });
          }
        });

        panels.forEach((panel, index) => {
          if (!(panel instanceof HTMLElement)) return;
          panel.hidden = index !== nextIndex;
        });
      };

      const onPointerDown = (event) => {
        if (event.pointerType === "touch") return;
        if (event.button !== 0) return;

        pointerActive = true;
        dragMoved = false;
        suppressClick = false;
        startX = event.clientX;
        startScrollLeft = scroll.scrollLeft;
        scroll.dataset.dragging = "true";
        if (typeof scroll.setPointerCapture === "function") {
          scroll.setPointerCapture(event.pointerId);
        }
      };

      const onPointerMove = (event) => {
        if (!pointerActive) return;

        const distance = event.clientX - startX;
        if (Math.abs(distance) > 6) {
          dragMoved = true;
          suppressClick = true;
        }

        scroll.scrollLeft = startScrollLeft - distance;
      };

      const onPointerEnd = () => {
        if (!pointerActive) return;

        pointerActive = false;
        delete scroll.dataset.dragging;
        window.setTimeout(() => {
          suppressClick = false;
          dragMoved = false;
        }, 0);
      };

      tabs.forEach((tab, index) => {
        if (!(tab instanceof HTMLElement)) return;

        tab.addEventListener("click", (event) => {
          if (suppressClick) {
            event.preventDefault();
            return;
          }

          activate(index);
        });

        tab.addEventListener("keydown", (event) => {
          let nextIndex = index;

          if (event.key === "ArrowRight" || event.key === "ArrowDown") {
            nextIndex = (index + 1) % tabs.length;
          } else if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
            nextIndex = (index - 1 + tabs.length) % tabs.length;
          } else if (event.key === "Home") {
            nextIndex = 0;
          } else if (event.key === "End") {
            nextIndex = tabs.length - 1;
          } else {
            return;
          }

          event.preventDefault();
          activate(nextIndex);
          const nextTab = tabs[nextIndex];
          if (nextTab instanceof HTMLElement) nextTab.focus();
        });
      });

      scroll.addEventListener("pointerdown", onPointerDown);
      scroll.addEventListener("pointermove", onPointerMove);
      scroll.addEventListener("pointerup", onPointerEnd);
      scroll.addEventListener("pointercancel", onPointerEnd);
      scroll.addEventListener("pointerleave", onPointerEnd);

      activate(0, false);
    });
  })();
</script>

<style>
  .history-hero {
    padding: 1.35rem;
    display: grid;
    gap: 1.35rem;
    position: relative;
    overflow: hidden;
  }

  .history-hero-header {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 1rem;
    align-items: start;
  }

  .history-stats {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .history-stat {
    padding: 1rem;
    border-radius: 1rem;
    border: 1px solid rgba(23, 29, 36, 0.08);
    background: rgba(255, 255, 255, 0.4);
    display: grid;
    gap: 0.3rem;
  }

  .history-stat strong {
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 0.9;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .history-stat span,
  .history-stat small {
    color: var(--ink-soft);
    line-height: 1.6;
  }

  .history-stat span {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .history-track-shell {
    display: grid;
    gap: 0.8rem;
  }

  .history-track-copy {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .history-track-copy p {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.7;
  }

  .history-track-frame {
    position: relative;
    padding: 1.2rem 0 0.8rem;
    border-block: 1px solid rgba(23, 29, 36, 0.08);
  }

  .history-track-frame::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    background:
      linear-gradient(90deg, rgba(180, 59, 36, 0), rgba(180, 59, 36, 0.34) 8%, rgba(144, 113, 69, 0.42) 50%, rgba(180, 59, 36, 0.34) 92%, rgba(180, 59, 36, 0));
    transform: translateY(-50%);
    pointer-events: none;
  }

  .history-track-scroll {
    overflow-x: auto;
    scrollbar-width: thin;
    cursor: grab;
    scroll-snap-type: x proximity;
    touch-action: pan-x;
  }

  .history-track-scroll[data-dragging="true"] {
    cursor: grabbing;
    scroll-behavior: auto;
  }

  .history-track {
    display: grid;
    gap: 1rem;
    grid-auto-flow: column;
    grid-auto-columns: minmax(210px, 1fr);
    min-height: 15.5rem;
    padding: 0 0 0.2rem;
  }

  .history-stop {
    border: 0;
    padding: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 0.85rem;
    align-items: center;
    min-height: 100%;
    position: relative;
    scroll-snap-align: center;
    cursor: pointer;
    text-align: left;
  }

  .history-stop::before {
    content: "";
    position: absolute;
    left: 50%;
    width: 1px;
    background:
      linear-gradient(180deg, rgba(144, 113, 69, 0.08), rgba(180, 59, 36, 0.42));
    transform: translateX(-50%);
  }

  .history-stop.is-top::before {
    top: calc(50% - 0.4rem);
    bottom: 4.9rem;
  }

  .history-stop.is-bottom::before {
    top: 4.9rem;
    bottom: calc(50% - 0.4rem);
  }

  .history-stop-card {
    padding: 0.85rem 0.95rem;
    border-radius: 1rem;
    border: 1px solid rgba(23, 29, 36, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0.24)),
      rgba(180, 59, 36, 0.04);
    display: grid;
    gap: 0.45rem;
    box-shadow: 0 14px 36px rgba(23, 29, 36, 0.08);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease;
    position: relative;
    overflow: hidden;
  }

  .history-stop-card::after {
    content: "";
    position: absolute;
    inset: auto -18% -62% auto;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(180, 59, 36, 0.12), transparent 72%);
    pointer-events: none;
  }

  .history-stop.is-top .history-stop-card {
    grid-row: 1;
  }

  .history-stop.is-bottom .history-stop-card {
    grid-row: 3;
  }

  .history-stop-card strong {
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: clamp(1.35rem, 2.3vw, 1.8rem);
    line-height: 0.96;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .history-stop-duration {
    color: var(--signal);
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .history-stop-marker {
    grid-row: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .history-stop-dot {
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    background: linear-gradient(180deg, #cf6546, #8f2b19);
    box-shadow:
      0 0 0 6px rgba(180, 59, 36, 0.14),
      0 0 0 12px rgba(144, 113, 69, 0.08);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .history-stop-year {
    margin-top: 0.7rem;
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: 1.5rem;
    line-height: 0.9;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--navy);
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.55);
  }

  .history-stop:hover .history-stop-card,
  .history-stop:focus-visible .history-stop-card,
  .history-stop.is-active .history-stop-card {
    transform: translateY(-0.2rem);
    border-color: rgba(180, 59, 36, 0.24);
    box-shadow: 0 22px 44px rgba(23, 29, 36, 0.12);
  }

  .history-stop.is-active .history-stop-card {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0.28)),
      rgba(180, 59, 36, 0.08);
  }

  .history-stop:hover .history-stop-dot,
  .history-stop:focus-visible .history-stop-dot,
  .history-stop.is-active .history-stop-dot {
    transform: scale(1.08);
    box-shadow:
      0 0 0 8px rgba(180, 59, 36, 0.14),
      0 0 0 16px rgba(144, 113, 69, 0.08);
  }

  .history-stop:focus-visible {
    outline: none;
  }

  .history-detail-stage {
    display: grid;
  }

  .history-detail {
    padding: 1.1rem 1.15rem 1.2rem;
    border-radius: 1rem;
    border: 1px solid rgba(23, 29, 36, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.68), rgba(255, 255, 255, 0.26)),
      rgba(144, 113, 69, 0.05);
    box-shadow: 0 20px 40px rgba(23, 29, 36, 0.08);
    display: grid;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
  }

  .history-detail::after {
    content: "";
    position: absolute;
    inset: auto -16% -58% auto;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(180, 59, 36, 0.1), transparent 72%);
    pointer-events: none;
  }

  .history-detail[hidden] {
    display: none;
  }

  .history-detail-head {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    align-items: center;
  }

  .history-hit-meta {
    margin: 0;
    color: var(--ink-soft);
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.7;
  }

  .history-detail h3 {
    margin: 0;
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: clamp(2rem, 3vw, 2.7rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .history-detail p:last-of-type,
  .history-hero-footer p {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.8;
  }

  .history-hero-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-top: 0.2rem;
    border-top: 1px solid rgba(23, 29, 36, 0.08);
  }

  .history-hero-footer p {
    max-width: 48rem;
  }

  :global(html[lang="zh-CN"]) .history-stat strong,
  :global(html[lang="zh-CN"]) .history-stop-card strong,
  :global(html[lang="zh-CN"]) .history-stop-year,
  :global(html[lang="zh-CN"]) .history-detail h3 {
    font-family: "Noto Sans SC", "PingFang SC", sans-serif;
    text-transform: none;
    letter-spacing: 0.01em;
  }

  :global(html[lang="zh-CN"]) .history-stat span,
  :global(html[lang="zh-CN"]) .history-hit-meta,
  :global(html[lang="zh-CN"]) .history-stop-duration {
    font-family: "Noto Sans SC", "PingFang SC", sans-serif;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  @media (max-width: 980px) {
    .history-hero-header {
      grid-template-columns: 1fr;
    }

    .history-stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .history-track-copy,
    .history-hero-footer {
      display: grid;
    }
  }

  @media (max-width: 720px) {
    .history-stats {
      grid-template-columns: 1fr;
    }

    .history-track-copy {
      gap: 0.45rem;
    }

    .history-track-frame {
      padding-top: 1rem;
    }

    .history-track {
      grid-auto-columns: minmax(72vw, 1fr);
      min-height: 13.5rem;
    }

    .history-stop-card strong {
      font-size: 1.3rem;
    }
  }
</style>
