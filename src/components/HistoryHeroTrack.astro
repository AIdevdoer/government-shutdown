---
import type { ShutdownHistoryContent } from "../data/shutdown-history";

interface Props {
  content: ShutdownHistoryContent;
  ctaHref: string;
}

const { content, ctaHref } = Astro.props;
---

<section class="card history-hero">
  <div class="history-hero-header">
    <div class="section-heading">
      <span class="eyebrow">{content.eyebrow}</span>
      <h2>{content.highlightTitle}</h2>
      <p>{content.highlightText}</p>
    </div>
    <div class="history-stats">
      {content.stats.map((stat) => (
        <article class="history-stat">
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
          {stat.note && <small>{stat.note}</small>}
        </article>
      ))}
    </div>
  </div>

  <div class="history-track-frame">
    <div class="history-track">
      {content.highlights.map((event, index) => (
        <article class={`history-stop ${index % 2 === 0 ? "is-top" : "is-bottom"}`}>
          <div class="history-stop-panel">
            <p class="history-hit-meta">{event.fiscalYear} · {event.span}</p>
            <h3>{event.title}</h3>
            <p>{event.summary}</p>
            <div class="history-stop-footer">
              <span class="chip">{event.duration}</span>
            </div>
          </div>
          <div class="history-stop-marker">
            <span class="history-stop-dot" aria-hidden="true"></span>
            <span class="history-stop-year">{event.year}</span>
          </div>
          <div class="history-stop-panel ghost-panel" aria-hidden="true"></div>
        </article>
      ))}
    </div>
  </div>

  <div class="history-hero-footer">
    <p>{content.disclaimerText}</p>
    <a class="cta-link" href={ctaHref}>{content.highlightCtaLabel}</a>
  </div>
</section>

<style>
  .history-hero {
    padding: 1.35rem;
    display: grid;
    gap: 1.35rem;
    position: relative;
    overflow: hidden;
  }

  .history-hero-header {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 1rem;
    align-items: start;
  }

  .history-stats {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .history-stat {
    padding: 1rem;
    border-radius: 1rem;
    border: 1px solid rgba(23, 29, 36, 0.08);
    background: rgba(255, 255, 255, 0.4);
    display: grid;
    gap: 0.3rem;
  }

  .history-stat strong {
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 0.9;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .history-stat span,
  .history-stat small {
    color: var(--ink-soft);
    line-height: 1.6;
  }

  .history-stat span {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .history-track-frame {
    position: relative;
    padding: 0.55rem 0 0.35rem;
    border-block: 1px solid rgba(23, 29, 36, 0.08);
  }

  .history-track-frame::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    background:
      linear-gradient(90deg, rgba(180, 59, 36, 0), rgba(180, 59, 36, 0.35) 8%, rgba(144, 113, 69, 0.42) 50%, rgba(180, 59, 36, 0.35) 92%, rgba(180, 59, 36, 0));
    transform: translateY(-50%);
    pointer-events: none;
  }

  .history-track {
    display: grid;
    gap: 1.15rem;
    grid-auto-flow: column;
    grid-auto-columns: minmax(250px, 1fr);
    overflow-x: auto;
    padding: 0.4rem 0 0.6rem;
    scrollbar-width: thin;
    scroll-snap-type: x proximity;
  }

  .history-stop {
    min-height: 31rem;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 1rem;
    position: relative;
    scroll-snap-align: start;
  }

  .history-stop::before {
    content: "";
    position: absolute;
    left: 50%;
    width: 1px;
    background:
      linear-gradient(180deg, rgba(144, 113, 69, 0.08), rgba(180, 59, 36, 0.42));
    transform: translateX(-50%);
  }

  .history-stop.is-top::before {
    top: calc(50% - 0.4rem);
    bottom: 5.3rem;
  }

  .history-stop.is-bottom::before {
    top: 5.3rem;
    bottom: calc(50% - 0.4rem);
  }

  .history-stop-panel,
  .ghost-panel {
    padding: 1rem 1rem 1.1rem;
    border-radius: 1rem;
    border: 1px solid rgba(23, 29, 36, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0.24)),
      rgba(180, 59, 36, 0.04);
    display: grid;
    gap: 0.7rem;
    box-shadow: 0 18px 40px rgba(23, 29, 36, 0.08);
    position: relative;
    overflow: hidden;
  }

  .history-stop-panel::after {
    content: "";
    position: absolute;
    inset: auto -14% -50% auto;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(180, 59, 36, 0.12), transparent 72%);
    pointer-events: none;
  }

  .history-stop.is-bottom .history-stop-panel {
    grid-row: 3;
  }

  .ghost-panel {
    visibility: hidden;
    pointer-events: none;
  }

  .history-stop.is-bottom .ghost-panel {
    grid-row: 1;
  }

  .history-stop.is-top .ghost-panel {
    grid-row: 3;
  }

  .history-stop-footer {
    display: flex;
    justify-content: flex-start;
    align-items: center;
  }

  .history-stop-marker {
    grid-row: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .history-stop-dot {
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    background: linear-gradient(180deg, #cf6546, #8f2b19);
    box-shadow:
      0 0 0 6px rgba(180, 59, 36, 0.14),
      0 0 0 12px rgba(144, 113, 69, 0.08);
  }

  .history-stop-year {
    margin-top: 0.7rem;
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: 1.6rem;
    line-height: 0.9;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--navy);
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.55);
  }

  .history-hit-meta {
    margin: 0;
    color: var(--ink-soft);
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.7;
  }

  .history-stop-panel h3 {
    margin: 0;
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: clamp(1.75rem, 2.8vw, 2.15rem);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .history-stop-panel p:last-of-type,
  .history-hero-footer p {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.8;
  }

  .history-hero-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding-top: 0.2rem;
    border-top: 1px solid rgba(23, 29, 36, 0.08);
  }

  .history-hero-footer p {
    max-width: 48rem;
  }

  :global(html[lang="zh-CN"]) .history-stat strong,
  :global(html[lang="zh-CN"]) .history-stop-panel h3,
  :global(html[lang="zh-CN"]) .history-stop-year {
    font-family: "Noto Sans SC", "PingFang SC", sans-serif;
    text-transform: none;
    letter-spacing: 0.01em;
  }

  :global(html[lang="zh-CN"]) .history-stat span,
  :global(html[lang="zh-CN"]) .history-hit-meta {
    font-family: "Noto Sans SC", "PingFang SC", sans-serif;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  @media (max-width: 980px) {
    .history-hero-header {
      grid-template-columns: 1fr;
    }

    .history-stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .history-hero-footer {
      display: grid;
    }
  }

  @media (max-width: 720px) {
    .history-stats {
      grid-template-columns: 1fr;
    }

    .history-track-frame::before {
      top: 2.2rem;
      transform: none;
    }

    .history-track {
      grid-auto-columns: minmax(84vw, 1fr);
    }

    .history-stop {
      min-height: auto;
      grid-template-rows: auto auto;
      gap: 0.85rem;
      padding-top: 1.4rem;
    }

    .history-stop::before,
    .ghost-panel {
      display: none;
    }

    .history-stop.is-bottom .history-stop-panel,
    .history-stop.is-top .history-stop-panel {
      grid-row: 2;
    }

    .history-stop-marker {
      grid-row: 1;
      flex-direction: row;
      justify-content: flex-start;
      gap: 0.65rem;
    }

    .history-stop-year {
      margin-top: 0;
    }
  }
</style>
