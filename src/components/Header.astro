---
const links = [
  { href: "/", label: "Watch" },
  { href: "/government-shutdown-federal-workers/", label: "Workers" },
  { href: "/government-shutdown-tax-refunds/", label: "Taxes" },
  { href: "/government-shutdown-passports/", label: "Travel" },
  { href: "/government-shutdown-social-security/", label: "Benefits" },
  { href: "/about/", label: "About" }
];
---

<header class="site-header">
  <div class="shell">
    <div class="notice-strip">
      <span class="surface-label">Independent Watch</span>
      <p>Not affiliated with the U.S. government. This site summarizes public information and publishes independent analysis.</p>
    </div>
    <div class="masthead card">
      <a class="brand" href="/">
        <span class="brand-mark">GS</span>
        <div>
          <strong>Government Shutdown</strong>
          <span>Federal funding clock, agency impacts, and worker guidance.</span>
        </div>
      </a>
      <nav aria-label="Primary navigation">
        {links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </nav>
    </div>
  </div>
</header>

<style>
  .site-header {
    padding: 1rem 0 0;
  }

  .notice-strip {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 0 0.35rem 0.8rem;
  }

  .notice-strip p {
    margin: 0;
    max-width: 48rem;
    color: var(--ink-soft);
    font-size: 0.92rem;
    line-height: 1.6;
    text-align: right;
  }

  .masthead {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    position: relative;
  }

  .masthead::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg, rgba(180, 59, 36, 0.1), transparent 35%),
      linear-gradient(90deg, transparent, rgba(36, 54, 73, 0.08));
    pointer-events: none;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    position: relative;
    z-index: 1;
  }

  .brand strong {
    display: block;
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: 1.6rem;
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .brand span:last-child {
    display: block;
    color: var(--ink-soft);
    font-size: 0.9rem;
  }

  .brand-mark {
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    border-radius: 0.9rem;
    background: var(--ink);
    color: var(--paper-strong);
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: 1.25rem;
    letter-spacing: 0.08em;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
  }

  nav a {
    padding: 0.7rem 0.9rem;
    border-radius: 999px;
    font-family: "Barlow Condensed", Impact, sans-serif;
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.42);
    border: 1px solid rgba(23, 29, 36, 0.1);
  }

  @media (max-width: 820px) {
    .notice-strip,
    .masthead {
      display: grid;
    }

    .notice-strip p {
      text-align: left;
    }

    nav {
      justify-content: flex-start;
    }
  }
</style>
